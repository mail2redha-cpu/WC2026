{
  "version": 2,
  "buildCommand": "echo 'No build needed'",
  "public": "public",
  "builds": [
    { "src": "api/extract.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/.*", "dest": "/api/extract.js" },
    { "src": "/.*\\.(js|css|svg|ico|json|txt|md)$", "dest": "/public/$1" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
